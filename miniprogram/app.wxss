page {
  min-height: 100vh;
  color: #101522;
  background:
    radial-gradient(circle at 8% -8%, rgba(18, 200, 255, 0.22), transparent 31%),
    radial-gradient(circle at 97% 4%, rgba(255, 79, 154, 0.14), transparent 26%),
    radial-gradient(circle at 78% 46%, rgba(109, 93, 252, 0.12), transparent 34%),
    linear-gradient(180deg, #fbfdff 0%, #eef4ff 58%, #f7f8fc 100%);
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", sans-serif;
}

view,
text,
input,
picker,
button,
image {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 44rpx;
}

.app-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 6rpx 4rpx 28rpx;
}

.title-block .title {
  color: #0e1424;
  font-size: 56rpx;
  line-height: 1.05;
  font-weight: 800;
}

.title-block .subtitle {
  margin-top: 10rpx;
  color: #697386;
  font-size: 26rpx;
}

.icon-button {
  width: 88rpx;
  height: 88rpx;
  border-radius: 32rpx;
  color: #6d5dfc;
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.9), rgba(235, 241, 255, 0.78)),
    rgba(109, 93, 252, 0.1);
  border: 1rpx solid rgba(109, 93, 252, 0.14);
  box-shadow: 0 16rpx 44rpx rgba(26, 38, 72, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.card {
  margin-top: 22rpx;
  border: 1rpx solid rgba(92, 109, 145, 0.16);
  border-radius: 36rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(249, 251, 255, 0.88)),
    rgba(255, 255, 255, 0.88);
  box-shadow: 0 36rpx 76rpx rgba(26, 38, 72, 0.12);
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 28rpx 16rpx;
}

.card-title {
  color: #101522;
  font-size: 32rpx;
  font-weight: 800;
}

.muted {
  color: #697386;
}

.quiet-action {
  min-height: 64rpx;
  padding: 0 12rpx;
  border-radius: 20rpx;
  color: #6d5dfc;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.segmented {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: 1fr;
  padding: 6rpx;
  border: 1rpx solid rgba(32, 46, 74, 0.12);
  border-radius: 28rpx;
  background: rgba(226, 234, 249, 0.78);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.74);
}

.segmented button {
  min-height: 72rpx;
  border-radius: 22rpx;
  color: #505c72;
  font-size: 28rpx;
  font-weight: 700;
}

.segmented button.active {
  color: #fff;
  background: linear-gradient(135deg, rgba(18, 200, 255, 0.98), #6d5dfc 54%, #4636d9);
  box-shadow: 0 16rpx 36rpx rgba(73, 61, 217, 0.28), inset 0 2rpx 0 rgba(255, 255, 255, 0.32);
}

.primary-button {
  width: 100%;
  min-height: 88rpx;
  border-radius: 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #12c8ff, #6d5dfc 52%, #4636d9);
  box-shadow: 0 24rpx 48rpx rgba(73, 61, 217, 0.28), inset 0 2rpx 0 rgba(255, 255, 255, 0.25);
  font-size: 30rpx;
  font-weight: 800;
}

.empty-state {
  padding: 30rpx 28rpx;
  color: #7d879b;
  font-size: 26rpx;
  text-align: center;
}

.field {
  display: grid;
  gap: 10rpx;
}

.field-label {
  color: #697386;
  font-size: 24rpx;
  font-weight: 700;
}

.field-input,
.field-picker {
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  color: #101522;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(92, 109, 145, 0.14);
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.status-text {
  min-height: 36rpx;
  color: #6d5dfc;
  font-size: 24rpx;
  font-weight: 700;
}
