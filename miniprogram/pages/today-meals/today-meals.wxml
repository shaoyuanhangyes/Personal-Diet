<view class="page today-page">
  <view class="app-header">
    <view class="title-block">
      <view class="title">今日餐食</view>
      <view class="subtitle">记录今天实际吃下的食物和数量</view>
    </view>
  </view>

  <view class="today-summary">
    <view class="summary-metric"><view class="label">热量</view><view class="value">{{summary.kcal}}</view></view>
    <view class="summary-metric"><view class="label">碳水</view><view class="value">{{summary.carbs}}</view></view>
    <view class="summary-metric"><view class="label">蛋白质</view><view class="value">{{summary.protein}}</view></view>
    <view class="summary-metric"><view class="label">脂肪</view><view class="value">{{summary.fat}}</view></view>
  </view>

  <view class="card form-card">
    <view class="card-header">
      <view class="card-title">添加今日餐食</view>
    </view>
    <view class="today-form">
      <view class="field">
        <view class="field-label">选择食物</view>
        <picker mode="selector" range="{{foodNames}}" value="{{selectedIndex}}" bindchange="changeFood">
          <view class="field-picker">{{selectedFoodLabel}}</view>
        </picker>
      </view>
      <view class="field">
        <view class="field-label">今日数量</view>
        <input class="field-input" type="digit" value="{{quantity}}" bindinput="inputQuantity" placeholder="例如 0.25" />
        <view class="field-hint">{{servingPreview}}</view>
      </view>
      <button class="primary-button add-meal-button {{addButtonClass}}" bindtap="addMeal">{{addButtonText}}</button>
      <view class="status-text">{{status}}</view>
    </view>
  </view>

  <view class="card meal-list">
    <view class="card-header">
      <view class="card-title">今日记录</view>
      <view class="quiet-action clear-action" bindtap="clearMeals" role="button" aria-label="清空今日记录">清空</view>
    </view>
    <view wx:if="{{noMeals}}" class="empty-state">还没有添加今日餐食</view>
    <block wx:if="{{hasMeals}}">
      <block wx:for="{{meals}}" wx:key="id">
        <view class="today-row {{item.rowClass}}">
          <view class="food-avatar">{{item.initial}}</view>
          <view class="meal-info">
            <view class="meal-title-line">
              <text class="meal-name">{{item.name}}</text>
              <text class="meal-serving">{{item.serving}}</text>
            </view>
            <view class="meal-desc">{{item.energy}} · 碳水 {{item.carbs}}g · 蛋白质 {{item.protein}}g · 脂肪 {{item.fat}}g</view>
            <view wx:if="{{item.hasConsumedAt}}" class="meal-time">摄入时间 {{item.consumedAtText}}</view>
          </view>
          <view class="delete-button" data-id="{{item.id}}" bindtap="deleteMeal" role="button" aria-label="删除餐食">
            <view class="trash-icon">
              <view class="trash-lid"></view>
              <view class="trash-can">
                <view class="trash-line"></view>
                <view class="trash-line"></view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </block>
    <view wx:if="{{showPagination}}" class="meal-pagination">
      <view class="meal-page-button {{prevDisabled ? 'is-disabled' : ''}}" bindtap="prevPage" role="button" aria-disabled="{{prevDisabled}}">上一页</view>
      <view class="meal-page-text">{{pageText}}</view>
      <view class="meal-page-button {{nextDisabled ? 'is-disabled' : ''}}" bindtap="nextPage" role="button" aria-disabled="{{nextDisabled}}">下一页</view>
    </view>
  </view>
</view>
