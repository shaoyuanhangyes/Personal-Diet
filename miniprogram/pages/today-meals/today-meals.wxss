.today-summary {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.summary-metric {
  min-width: 0;
  border-radius: 24rpx;
  padding: 18rpx 10rpx;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.74), rgba(244, 248, 255, 0.7)), rgba(109, 93, 252, 0.08);
  border: 1rpx solid rgba(109, 93, 252, 0.1);
  box-shadow: 0 16rpx 44rpx rgba(26, 38, 72, 0.08);
  text-align: center;
}

.summary-metric .label {
  color: #697386;
  font-size: 22rpx;
  line-height: 1.2;
}

.summary-metric .value {
  margin-top: 8rpx;
  color: #101522;
  font-size: 25rpx;
  line-height: 1.18;
  font-weight: 800;
  white-space: nowrap;
}

.today-form {
  display: grid;
  gap: 22rpx;
  padding: 8rpx 28rpx 28rpx;
}

.field-hint {
  color: #7d879b;
  font-size: 22rpx;
}

.add-meal-button {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  text-align: center;
  transition: transform 160ms ease, background 160ms ease, box-shadow 160ms ease;
}

.add-meal-button.is-success {
  transform: scale(0.98);
  background: linear-gradient(135deg, #16c784, #0fa968);
  box-shadow: 0 12rpx 30rpx rgba(22, 199, 132, 0.28);
}

.meal-list .card-header {
  align-items: center;
}

.meal-list .clear-action {
  width: 64rpx;
  min-width: 64rpx;
  height: 48rpx;
  margin-left: auto;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  color: #6d5dfc;
  font-size: 26rpx;
  font-weight: 800;
}

.today-row {
  display: grid;
  grid-template-columns: 76rpx 1fr 64rpx;
  gap: 18rpx;
  align-items: center;
  min-height: 112rpx;
  padding: 18rpx 28rpx;
  border-top: 1rpx solid rgba(32, 46, 74, 0.08);
}

.today-row.is-new {
  animation: meal-added 520ms ease-out both;
}

.meal-pagination {
  display: grid;
  grid-template-columns: 144rpx 1fr 144rpx;
  gap: 18rpx;
  align-items: center;
  padding: 24rpx;
  border-top: 1rpx solid rgba(32, 46, 74, 0.08);
}

.meal-page-button {
  width: 100%;
  height: 64rpx;
  border-radius: 22rpx;
  color: #6d5dfc;
  background: rgba(109, 93, 252, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
}

.meal-page-button.is-disabled {
  color: #9ba5b5;
  background: rgba(155, 165, 181, 0.1);
  opacity: 0.58;
}

.meal-page-text {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #697386;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
}

@keyframes meal-added {
  0% {
    opacity: 0;
    transform: translateY(-18rpx) scale(0.98);
    background: rgba(22, 199, 132, 0.18);
  }
  55% {
    opacity: 1;
    transform: translateY(0) scale(1);
    background: rgba(22, 199, 132, 0.12);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
    background: transparent;
  }
}

.food-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #12c8ff, #6d5dfc);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.meal-info {
  min-width: 0;
}

.meal-title-line {
  display: flex;
  align-items: baseline;
  min-width: 0;
}

.meal-name {
  color: #101522;
  font-size: 28rpx;
  font-weight: 800;
  min-width: 0;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meal-serving,
.meal-desc,
.meal-time {
  color: #697386;
  font-size: 22rpx;
}

.meal-time {
  margin-top: 6rpx;
  color: #8791a3;
}

.meal-serving {
  flex-shrink: 0;
  margin-left: 18rpx;
}

.delete-button {
  width: 64rpx;
  height: 64rpx;
  border-radius: 24rpx;
  background: rgba(255, 79, 104, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.trash-icon {
  position: relative;
  width: 34rpx;
  height: 38rpx;
}

.trash-lid {
  position: absolute;
  left: 4rpx;
  top: 0;
  width: 26rpx;
  height: 6rpx;
  border-radius: 5rpx;
  background: #ff4f68;
}

.trash-can {
  position: absolute;
  left: 6rpx;
  top: 10rpx;
  width: 22rpx;
  height: 25rpx;
  border: 4rpx solid #ff4f68;
  border-top-width: 3rpx;
  border-radius: 3rpx 3rpx 6rpx 6rpx;
  display: flex;
  justify-content: center;
  gap: 4rpx;
  padding-top: 5rpx;
}

.trash-line {
  width: 3rpx;
  height: 14rpx;
  border-radius: 3rpx;
  background: #ff4f68;
}
